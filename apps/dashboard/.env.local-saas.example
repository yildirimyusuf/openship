# Openship Dashboard — localhost SaaS dev. Copy to `.env.saas`; `dev:saas` loads it
# (node --env-file=.env.saas). Selecting this file is the ONLY difference from `dev`.
# Serves on :3002 into the .next-saas build dir so it never clobbers local (.next).
OPENSHIP_TARGET=local-saas
OPENSHIP_CLOUD_TARGET=local-saas
PORT=3002
NEXT_DIST_DIR=.next-saas
