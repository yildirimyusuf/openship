{
  "name": "@repo/dashboard",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "dev": "ENV_FILE=.env node --import ./scripts/load-env.mjs node_modules/next/dist/bin/next dev",
    "dev:saas": "ENV_FILE=.env.saas node --import ./scripts/load-env.mjs node_modules/next/dist/bin/next dev",
    "dev:local-saas": "ENV_FILE=.env.local-saas node --import ./scripts/load-env.mjs node_modules/next/dist/bin/next dev",
    "dev:fresh": "rm -rf .next/cache && ENV_FILE=.env node --import ./scripts/load-env.mjs node_modules/next/dist/bin/next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "clean": "rm -rf .next .turbo node_modules"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@repo/core": "workspace:*",
    "@repo/onboarding": "workspace:*",
    "@repo/ui": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "better-auth": "^1.5.4",
    "chart.js": "^4.4.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.20",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^22.13.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
