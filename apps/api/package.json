{
  "name": "@repo/api",
  "version": "0.1.11",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "OPENSHIP_DEV_LOCK_TAKEOVER=true node --env-file=.env --import tsx --watch src/index.ts",
    "dev:saas": "OPENSHIP_DEV_LOCK_TAKEOVER=true node --env-file=.env.saas --import tsx --watch src/index.ts",
    "dev:local-saas": "OPENSHIP_DEV_LOCK_TAKEOVER=true node --env-file=.env.local-saas --import tsx --watch src/index.ts",
    "build": "tsup src/index.ts --format esm && node scripts/copy-assets.mjs",
    "build-release": "bun scripts/build-release.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.5.4",
    "@hono/node-server": "^1.19.11",
    "@hono/node-ws": "^1.3.1",
    "@hono/typebox-validator": "^0.3.0",
    "@repo/adapters": "workspace:*",
    "@repo/core": "workspace:*",
    "@repo/db": "workspace:*",
    "@sinclair/typebox": "^0.34.48",
    "better-auth": "^1.5.4",
    "bullmq": "^5.70.4",
    "cron-parser": "^4.9.0",
    "hono": "^4.12.5",
    "ioredis": "^5.10.0",
    "maxmind": "^5.0.6",
    "nodemailer": "^9.0.1",
    "pino": "^10.3.1",
    "stripe": "^20.4.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/nodemailer": "^8.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
